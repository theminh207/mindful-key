    },
    {
      "id": "function:platforms/windows/win32/OpenKey/OpenKeyUpdate/OpenKeyUpdate.cpp:UpdateThreadFunction",
      "type": "function",
      "name": "UpdateThreadFunction",
      "filePath": "platforms/windows/win32/OpenKey/OpenKeyUpdate/OpenKeyUpdate.cpp",
      "lineRange": [74, 130],
      "summary": "Hàm chạy trong thread nền thực hiện toàn bộ luồng cập nhật: tải version.json, tách chuỗi lấy versionName, tải file zip release từ GitHub, giải nén bằng PowerShell rồi thay thế OpenKey64.exe; báo kết quả lỗi/thành công qua MessageBox và thoát tiến trình.",
      "tags": ["network", "downloader", "file-replacement", "threading", "self-updater"],
      "complexity": "moderate",
      "languageNotes": "Dùng URLDownloadToFile (Urlmon) để tải và WinExec gọi PowerShell Expand-Archive để giải nén; parse JSON theo kiểu cắt chuỗi thủ công nên khá mong manh nếu định dạng version.json đổi."
    },
