# Xcode / XcodeGen (project.yml là nguồn thật — .xcodeproj sinh ra, không commit)
platforms/apple/*.xcodeproj/
platforms/apple/build/
build/
DerivedData/
*.dSYM
*.dSYM.zip

# Đóng gói
*.dmg
.dmg-staging/
release-out/

# macOS
.DS_Store

# Build artifact của tests/core
tests/core/test_engine
tests/core/test_send_risk
tests/core/test_phrasing

# Build artifact của tests/ios
tests/ios/bridge_test

# iOS host-test compiled binaries (không commit — chỉ commit .mm nguồn)
tests/ios/*_test

# Local/IDE configs
.claude/
*.html
# ...nhưng landing page trong site/ PHẢI được commit (deploy qua Coolify)
!site/**/*.html
# ...và tài liệu hướng dẫn minh họa trong docs/ cũng PHẢI được commit
!docs/**/*.html

# macOS host-test compiled binaries (không commit — chỉ commit .mm nguồn)
tests/macos/*_test

# Understand-Anything (bản đồ tri thức đọc hiểu code — rác tạm, không phải nguồn)
.ua/intermediate/
.ua/diff-overlay.json
