/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
// [MINDFUL] 2026-07-17 (GĐ6) — trỏ THẲNG sang bộ icon brand sinh từ SVG nguồn
// (brand/export-platform.sh -> brand/platform/windows/), KHÔNG chép vào thư mục Windows: chép là
// bản sao thứ hai của tài sản brand, đúng mô hình đã đẻ ra bug lexicon. Cùng cách .wav chuông đang
// làm. Đổi SVG -> chạy `make brand-platform` -> cả app đổi theo.
//
// Trước đó vỏ Windows chạy nguyên bộ icon MindfulKey 2019 (chữ "V") — kể cả ICON KHAY, thứ người
// dùng nhìn cả ngày. Con sóng `~` nay là icon khay thật (Status.svg).
IDI_APP_ICON            ICON                    "../../../../../brand/platform/windows/icon.ico"

IDI_ICON_STATUS_VIET    ICON                    "../../../../../brand/platform/windows/StatusViet.ico"

IDI_ICON_STATUS_ENG     ICON                    "../../../../../brand/platform/windows/StatusEng.ico"

// "*_10" là tên DI SẢN MindfulKey và nó NÓI DỐI: không phải "kiểu Windows 10" mà là bản XÁM
// (SystemTrayHelper.cpp:288 dùng khi vUseGrayIcon). Giữ tên vì đổi = đụng resource.h + mọi chỗ gọi,
// ngoài phạm vi GĐ6.
IDI_ICON_STATUS_VIET_10 ICON                    "../../../../../brand/platform/windows/StatusViet10.ico"

IDI_ICON_STATUS_ENG_10  ICON                    "../../../../../brand/platform/windows/StatusEng10.ico"

// Sóng biên độ CAO — "tâm đang động". Brand vẽ sẵn từ lâu; BRAND-ASSETS §6 ghi "cần wire" và tới
// 2026-07-17 CẢ macOS lẫn Windows đều chưa nối. Windows nối trước.
IDI_ICON_STATUS_ALERT   ICON                    "../../../../../brand/platform/windows/StatusAlert.ico"

IDI_ICON_OK_BUTTON      ICON                    "../../../../../brand/platform/windows/OKButton.ico"

IDI_ICON_EXIT_BUTTON    ICON                    "../../../../../brand/platform/windows/ExitButton.ico"

// CHƯA đổi: brand không có hình cho hành động "Cài đặt gốc", và bịa một cái là tự chế nhận diện.
// Giữ icon MindfulKey gốc cho nút này — xem docs/FRICTION-LOG.md 2026-07-17.
IDI_ICON_DEFAULT_BUTTON ICON                    "DefaultButton.ico"

IDI_ICON_START_CONVERT  ICON                    "../../../../../brand/platform/windows/StartConvert.ico"

// Icon 4 tab cửa sổ Điều khiển. Brand vẽ sẵn đúng 4 tab đang có, ĐÚNG THỨ TỰ — chưa ai nối.
IDI_TAB_BOGO            ICON                    "../../../../../brand/platform/windows/TabBoGo.ico"

IDI_TAB_GOTAT           ICON                    "../../../../../brand/platform/windows/TabGoTat.ico"

IDI_TAB_HETHONG         ICON                    "../../../../../brand/platform/windows/TabHeThong.ico"

IDI_TAB_THONGTIN        ICON                    "../../../../../brand/platform/windows/TabThongTin.ico"


/////////////////////////////////////////////////////////////////////////////
//
// WAVE — tiếng chuông tỉnh thức
//
// Trỏ THẲNG sang tệp vỏ macOS đang dùng: MỘT nguồn duy nhất cho cả 2 vỏ. Chép sang thư mục
// Windows là tạo bản sao thứ hai của tài sản brand — đúng mô hình đã đẻ ra bug lexicon.
// Tệp là Microsoft PCM 16-bit, phát thẳng bằng PlaySound(SND_MEMORY) — xem Bell.cpp.
//
IDR_WAVE_TEMPLE         WAVE                    "../../../../apple/macos/Chuông chùa.wav"
IDR_WAVE_CHIME          WAVE                    "../../../../apple/macos/Chuông gió.wav"
IDR_WAVE_WIND           WAVE                    "../../../../apple/macos/Chuông reo.wav"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDC_MINDFULKEY MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                       IDM_EXIT
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About ...",                  IDM_ABOUT
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDC_MINDFULKEY ACCELERATORS
BEGIN
    "?",            IDM_ABOUT,              ASCII,  ALT
    "/",            IDM_ABOUT,              ASCII,  ALT
END


