STRINGTABLE
BEGIN
    IDS_STRING_SPELLING_CHECK 
                            "Tính năng kiểm tra chính tả tương đối, hạn chế gõ sai từ, cải thiện việc gõ Tiếng Anh khi bật chế độ gõ Tiếng Việt"
    IDS_STRING_RESTORE_IF_WRONG_SPELLING 
                            "Từ nào sai Tiếng Việt thì tự động phục hồi lại những phím đã gõ"
    IDS_STRING_USE_CLIPBOARD 
                            "Nếu có ứng dụng nào không thể gõ Tiếng Việt, hãy bật tính năng này lên. Bình thường thì không nên dùng tính năng này."
    IDS_STRING_ALLOW_ZWFJ   "Vẫn cho phép dùng các chữ z w f j làm phụ âm khi có bật tính năng kiểm tra chính tả"
    IDS_STRING_TEMP_OFF_SPELLING 
                            "Tạm tắt kiểm tra chính tả khi gõ một từ nào đó như từ Đắk Lắk, Krông,... Kiểm tra chính tả sẽ phục hồi trở lại cho từ tiếp theo"
    IDS_STRING_MODERN_ICON  "Dùng biểu tượng đồng bộ với task bar của Windows 10"
    IDS_STRING_CAPS_FIRST_CHAR 
                            "Tự động viết hoa sau dấu chấm ngắt câu và sau khi xuống dòng"
    IDS_STRING_SMART_SWITCH_KEY 
                            "Bạn đang sử dụng Chrome và dùng chế độ gõ Tiếng Việt, bạn chuyển qua Command Prompt và chuyển chế độ gõ qua Tiếng Anh, Mindful Keyboard sẽ tự ghi nhớ thao tác cho bạn, khi bạn chuyển về lại Chrome, Mindful Keyboard sẽ tự chuyển sang chế độ Tiếng Việt, sau đó nếu lại quay lại Command Prompt, Mindful Keyboard cũng sẽ tự đổi qua chế độ Tiếng Anh"
    IDS_STRING_SUPPORT_METRO 
                            "Hỗ trợ các ứng dụng Metro như Facebook Messenger, Instargram,..."
    IDS_STRING_RUN_ON_STARTUP "Tự chạy Mindful Keyboard khi khởi động Windows"
    IDS_STRING_SHOW_ON_STARTUP "Hiện bảng điều khiển mỗi lần chạy Mindful Keyboard"
    IDS_STRING_CREATE_DESKTOP 
                            "Tạo biểu tượng Mindful Keyboard ở Desktop để có thể tìm thấy nhanh khi cần thiết"
    IDS_STRING_RUN_AS_ADMIN "Khởi động lại Mindful Keyboard với quyền Admin để có thể gõ được tiếng Việt trong game, bạn sẽ được yêu cầu khởi động lại chương trình Mindful Keyboard"
    IDS_STRING_CHECK_UPDATE "Kiểm tra bản mới mỗi lần khởi động Mindful Keyboard"
    IDS_STRING_REMEMBER_TABLE_CODE 
                            "Mindful Keyboard sẽ tự động ghi nhớ bạn đã dùng bảng mã nào cho ứng dụng nào, để lần sau khi chuyển qua ứng dụng đó, Mindful Keyboard sẽ tự động chuyển sang bảng mã đó cho bạn. Rất thích hợp cho các ứng dụng kỹ thuật như Photoshop, CAD,..."
    IDS_STRING_TEMP_OFF_MINDFULKEY 
                            "Bằng cách bấm phím Alt, Mindful Keyboard sẽ tạm ngừng hoạt động cho tới khi bạn gõ 1 từ mới."
END

