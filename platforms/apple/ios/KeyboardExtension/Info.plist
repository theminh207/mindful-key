<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Mindful Key</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>XPC!</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.keyboard-service</string>
		<key>NSExtensionPrincipalClass</key>
		<string>KeyboardViewController</string>
		<key>NSExtensionAttributes</key>
		<dict>
			<!-- Round 2 (Mốc C) BẬT open access: bàn phím cần App Group (đọc macro + cài đặt
			     Telex/VNI từ container app) và đọc câu vừa gõ để con sóng ~ phản chiếu nhịp gõ.
			     TẤT CẢ xử lý ngay trên máy — không gửi/không lưu/không ai đọc (xem docs/PRIVACY-NOTE.md +
			     copy màn FullAccess). Không có open access thì iOS ẩn cả nút "Allow Full Access" trong
			     Cài đặt và bàn phím không mở được App Group (đã kiểm chứng 2026-07-13). -->
			<key>RequestsOpenAccess</key>
			<true/>
			<key>IsASCIICapable</key>
			<false/>
			<key>PrefersRightToLeft</key>
			<false/>
			<key>PrimaryLanguage</key>
			<string>vi-VN</string>
		</dict>
	</dict>
</dict>
</plist>
